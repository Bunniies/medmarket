// MedMarket — Prisma Schema
// Database: PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// AUTH
// ─────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  passwordHash  String?
  role                   UserRole  @default(HOSPITAL_STAFF)
  active                 Boolean   @default(true)
  emailNotifyMessages    Boolean   @default(true)
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  // Relations
  hospital      Hospital?  @relation(fields: [hospitalId], references: [id])
  hospitalId    String?
  listings               Listing[]
  orders                 Order[]         @relation("BuyerOrders")
  sessions               Session[]
  accounts               Account[]
  initiatedConversations Conversation[]  @relation("ConversationInitiator")
  sentMessages           Message[]
  adminLogs              AdminLog[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

enum UserRole {
  HOSPITAL_ADMIN
  HOSPITAL_STAFF
  PLATFORM_ADMIN
}

// ─────────────────────────────────────────────
// HOSPITAL
// ─────────────────────────────────────────────

model Hospital {
  id          String          @id @default(cuid())
  name        String
  slug        String          @unique
  address     String
  city        String
  country     String
  phone       String?
  email       String?
  vatNumber   String?         // For invoicing purposes
  verified    Boolean         @default(false)
  latitude    Float?
  longitude   Float?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  users       User[]
  listings    Listing[]
  buyOrders   Order[]         @relation("BuyerHospital")
  sellOrders  Order[]         @relation("SellerHospital")
  invitations Invitation[]

  @@map("hospitals")
}

// ─────────────────────────────────────────────
// MEDICINE / LISTING
// ─────────────────────────────────────────────

model Listing {
  id              String          @id @default(cuid())
  title           String
  description     String?         @db.Text
  medicineName    String
  genericName     String?
  atcCode         String?         // Anatomical Therapeutic Chemical classification
  manufacturer    String?
  batchNumber     String?
  expiryDate      DateTime
  quantity        Int
  unit            String          @default("units") // units, vials, boxes, etc.
  pricePerUnit    Decimal         @db.Decimal(10, 2)
  currency        String          @default("EUR")
  condition       MedicineCondition @default(SEALED)
  status          ListingStatus   @default(ACTIVE)
  images          String[]        // array of image URLs
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  // Relations
  seller          User            @relation(fields: [sellerId], references: [id])
  sellerId        String
  hospital        Hospital        @relation(fields: [hospitalId], references: [id])
  hospitalId      String
  orders          Order[]
  conversations   Conversation[]
  category        Category?       @relation(fields: [categoryId], references: [id])
  categoryId      String?

  @@map("listings")
}

enum MedicineCondition {
  SEALED
  OPENED        // opened but unused portion
}

enum ListingStatus {
  ACTIVE
  SOLD
  EXPIRED
  ARCHIVED
  PENDING_REVIEW
}

// ─────────────────────────────────────────────
// CATEGORY
// ─────────────────────────────────────────────

model Category {
  id       String    @id @default(cuid())
  name     String    @unique
  slug     String    @unique
  icon     String?
  listings Listing[]

  @@map("categories")
}

// ─────────────────────────────────────────────
// ORDER / TRANSACTION
// ─────────────────────────────────────────────

model Order {
  id              String        @id @default(cuid())
  orderNumber     String        @unique @default(cuid())
  quantity        Int
  unitPrice       Decimal       @db.Decimal(10, 2)
  totalPrice      Decimal       @db.Decimal(10, 2)
  currency        String        @default("EUR")
  status          OrderStatus   @default(PENDING)
  notes           String?       @db.Text
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // Relations
  listing         Listing       @relation(fields: [listingId], references: [id])
  listingId       String
  buyer           User          @relation("BuyerOrders", fields: [buyerId], references: [id])
  buyerId         String
  buyerHospital   Hospital      @relation("BuyerHospital", fields: [buyerHospitalId], references: [id])
  buyerHospitalId String
  sellerHospital  Hospital      @relation("SellerHospital", fields: [sellerHospitalId], references: [id])
  sellerHospitalId String

  @@map("orders")
}

// ─────────────────────────────────────────────
// INVITATIONS
// ─────────────────────────────────────────────

model Invitation {
  id         String           @id @default(cuid())
  email      String
  token      String           @unique @default(cuid())
  hospitalId String
  hospital   Hospital         @relation(fields: [hospitalId], references: [id], onDelete: Cascade)
  status     InvitationStatus @default(PENDING)
  expiresAt  DateTime
  createdAt  DateTime         @default(now())

  @@map("invitations")
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  SHIPPED
  DELIVERED
  CANCELLED
  DISPUTED
}

// ─────────────────────────────────────────────
// CHAT
// ─────────────────────────────────────────────

model Conversation {
  id                   String    @id @default(cuid())
  listingId            String
  listing              Listing   @relation(fields: [listingId], references: [id], onDelete: Cascade)
  initiatorId          String
  initiator            User      @relation("ConversationInitiator", fields: [initiatorId], references: [id])
  messages             Message[]
  initiatorLastReadAt  DateTime?
  sellerLastReadAt     DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@unique([listingId, initiatorId])
  @@map("conversations")
}

// ─────────────────────────────────────────────
// ADMIN AUDIT LOG
// ─────────────────────────────────────────────

model AdminLog {
  id            String   @id @default(cuid())
  action        String   // HOSPITAL_APPROVED, HOSPITAL_REJECTED, HOSPITAL_REVOKED,
                         // LISTING_REMOVED, USER_DEACTIVATED, USER_REACTIVATED
  targetType    String   // HOSPITAL | LISTING | USER
  targetId      String
  targetName    String   // denormalized — survives deletion of target
  performedBy   User     @relation(fields: [performedById], references: [id])
  performedById String
  createdAt     DateTime @default(now())

  @@map("admin_logs")
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User         @relation(fields: [senderId], references: [id])
  body           String       @db.Text
  createdAt      DateTime     @default(now())

  @@map("messages")
}
