# Database — replace with your PostgreSQL connection string
DATABASE_URL="postgresql://user:password@localhost:5432/medmarket"

# NextAuth — generate a strong secret: openssl rand -base64 32
AUTH_SECRET="your-secret-here"

# App URL
NEXTAUTH_URL="http://localhost:3000"

# Resend — email (password reset, alerts, invitations, order notifications)
# Without this key all email flows silently no-op; get a key at https://resend.com
# RESEND_API_KEY="re_..."

# Upstash Redis — login rate limiting (10 attempts / 15 min per IP)
# Without these keys rate limiting is disabled; create a free DB at https://upstash.com
# UPSTASH_REDIS_REST_URL="https://..."
# UPSTASH_REDIS_REST_TOKEN="..."

# Anthropic — AI-powered category suggestion in the listing form
# Without this key the "Suggest with AI" button is hidden; get a key at https://console.anthropic.com
# ANTHROPIC_API_KEY="sk-ant-..."
